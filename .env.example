PORT=3000
JWT_SECRET=change-me

# Recommended for Vercel/PostgreSQL providers such as Neon, Supabase, Railway, Render, etc.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SCHEMA=public
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MAX=2

# Local fallback if DATABASE_URL is not set.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=inventoryhouse
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Google Sign-In. Use GOOGLE_CLIENT_IDS for multiple mobile/web client IDs.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_IDS=web-client-id.apps.googleusercontent.com,android-client-id.apps.googleusercontent.com,ios-client-id.apps.googleusercontent.com
